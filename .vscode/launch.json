{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug NestJS",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "start:debug"
            ],
            "env": {
                "TS_NODE_PROJECT": "tsconfig.json"
            },
            "console": "integratedTerminal",
            "restart": true,
            "sourceMaps": true,
            "smartStep": true,
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}